# Base de donnees PostgreSQL
DATABASE_URL=postgres://user:password@localhost:5432/fba

# NextAuth
AUTH_SECRET=your-secret-here
AUTH_URL=http://localhost:3000

# Google OAuth
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# Resend (email)
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Admin seed (db:seed-admin)
ADMIN_EMAIL=admin@fondsbarnier.fr
ADMIN_PASSWORD=your-secure-password
ADMIN_NAME=Administrateur

# HubSpot webhook (app privée HubSpot → Paramètres → Intégrations → Applications privées)
HUBSPOT_CLIENT_SECRET=your-hubspot-app-client-secret

# Webhook Bearer token (n8n et integrations internes)
WEBHOOK_BEARER_TOKEN=your-webhook-bearer-token

# Stripe (paiement devis 250 EUR)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
