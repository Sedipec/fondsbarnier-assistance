{
  "name": "fonds-barnier-assistance",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "npx drizzle-kit push --force && sh scripts/deploy-notify.sh && next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "npx tsx db/seed.ts",
    "db:seed-admin": "npx tsx db/seed-admin.ts"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^1.7.0",
    "next": "^15.3.1",
    "next-auth": "^5.0.0-beta.30",
    "postgres": "^3.4.8",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "drizzle-kit": "^0.31.10",
    "resend": "^6.9.4",
    "tsx": "^4.19.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.1.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.3",
    "@vitejs/plugin-react": "^4.4.1",
    "daisyui": "^5.0.35",
    "eslint": "^9.25.1",
    "eslint-config-next": "^15.3.1",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
